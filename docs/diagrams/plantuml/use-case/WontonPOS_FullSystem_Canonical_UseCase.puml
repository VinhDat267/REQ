@startuml
' Final-project canonical full-system overview (PlantUML only)
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #DAE8FC
  BorderColor #6C8EBF
  ArrowColor #333333
}
skinparam rectangle {
  BorderColor #666666
}

title Wonton POS Final - Canonical Full-System Use Case Overview\nScope: CUC-01..CUC-25 (derived from UC-01..UC-74)

actor "Registered Customer" as RegisteredCustomer
actor "Guest Customer" as GuestCustomer
actor "Manager" as Manager
actor "FOH Cashier" as FOHCashier
actor "FOH Service" as FOHService
actor "BOH Staff" as BOH

rectangle "Wonton POS Final System" {
  package "Client WebApp" {
    usecase "CUC-01\nManage Customer Account" as CUC01
    usecase "CUC-02\nBrowse Menu and Find Items" as CUC02
    usecase "CUC-03\nCreate and Configure Customer Order" as CUC03
    usecase "CUC-04\nPrepay Takeaway / Pickup Order" as CUC04
    usecase "CUC-05\nPay Dine-in Order at Counter" as CUC05
    usecase "CUC-06\nTrack and Manage Active Order" as CUC06
    usecase "CUC-07\nView Order History and Reorder" as CUC07
    usecase "CUC-08\nPlace and Manage Pickup Order" as CUC08
    usecase "CUC-09\nSubmit Post-order Review" as CUC09
  }

  package "Admin WebApp - Manager" {
    usecase "CUC-10\nMonitor Operations Dashboard" as CUC10
    usecase "CUC-11\nManage Menu, Categories,\nToppings, and Availability" as CUC11
    usecase "CUC-12\nManage Shop Tables" as CUC12
    usecase "CUC-13\nManage Pickup Schedule\nand Pickup Exceptions" as CUC13
    usecase "CUC-14\nManage Staff and Access Roles" as CUC14
    usecase "CUC-16\nView Revenue Reports,\nShift Close, and Reconciliation" as CUC16
    usecase "CUC-17\nManage Promotions" as CUC17
  }

  package "Admin WebApp - Shared Access / Security" {
    usecase "CUC-15\nAccess Admin Workspace\nand Personal Security" as CUC15
  }

  package "Admin WebApp - FOH Cashier" {
    usecase "CUC-18\nCreate, Receive, Dispatch,\nand Review FOH Orders" as CUC18
    usecase "CUC-19\nHandle Order Cancellation\nand Order Exceptions" as CUC19
    usecase "CUC-20\nHandle Payment, Refund,\nand Payment Documents" as CUC20
    usecase "CUC-21\nManage Table Assignment,\nTransfer, and Release" as CUC21
  }

  package "Admin WebApp - BOH" {
    usecase "CUC-22\nReceive and Confirm Kitchen Orders" as CUC22
    usecase "CUC-23\nExecute Cooking and Update\nPreparation Progress" as CUC23
    usecase "CUC-24\nManage Kitchen-side Availability" as CUC24
  }

  package "Admin WebApp - FOH Service" {
    usecase "CUC-25\nHandle Handoff and Close\nTable Service Lifecycle" as CUC25
  }
}

' Actor associations
RegisteredCustomer -- CUC01
RegisteredCustomer -- CUC02
RegisteredCustomer -- CUC03
RegisteredCustomer -- CUC04
RegisteredCustomer -- CUC05
RegisteredCustomer -- CUC06
RegisteredCustomer -- CUC07
RegisteredCustomer -- CUC08
RegisteredCustomer -- CUC09

GuestCustomer -- CUC02
GuestCustomer -- CUC03
GuestCustomer -- CUC04
GuestCustomer -- CUC05
GuestCustomer -- CUC06
GuestCustomer -- CUC08

Manager -- CUC10
Manager -- CUC11
Manager -- CUC12
Manager -- CUC13
Manager -- CUC14
Manager -- CUC15
Manager -- CUC16
Manager -- CUC17
Manager -- CUC19

FOHCashier -- CUC15
FOHCashier -- CUC18
FOHCashier -- CUC19
FOHCashier -- CUC20
FOHCashier -- CUC21

BOH -- CUC15
BOH -- CUC22
BOH -- CUC23
BOH -- CUC24

FOHService -- CUC15
FOHService -- CUC25

' Canonical include / extend relations only
CUC03 ..> CUC02 : <<include>>
CUC04 ..> CUC03 : <<extend>>
CUC08 ..> CUC03 : <<extend>>
CUC08 ..> CUC04 : <<include>>
CUC19 ..> CUC18 : <<extend>>
CUC24 ..> CUC22 : <<extend>>
CUC24 ..> CUC23 : <<extend>>

legend right
Main canvas policy:
- Concrete actors only; no extra parent actors are introduced.
- Main UML canvas shows actor associations plus <<include>> / <<extend>> only.
- Semantic dependency edges remain in All_Use_Cases.md to keep the diagram readable.

Semantic dependencies tracked outside the main canvas:
- CUC-06 depends on CUC-03
- CUC-06 depends on CUC-08
- CUC-20 depends on CUC-18
- CUC-22 depends on CUC-18
- CUC-23 depends on CUC-22
- CUC-25 depends on CUC-23

Support-only note:
- UC-74 remains support-only under CUC-15 and is not drawn as a standalone use case.
end legend

@enduml
